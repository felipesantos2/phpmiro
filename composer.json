{
    "name": "testes/app",
    "require": {
        "symfony/dotenv": "^8.1",
        "symfony/var-dumper": "*",
        "monolog/monolog": "^3.10",
        "twig/twig": "^3.0",
        "symfony/console": "^8.1",
        "symfony/finder": "^8.1",
        "symfony/routing": "^8.1",
        "symfony/http-client": "^8.1",
        "symfony/error-handler": "^8.1",
        "symfony/http-foundation": "^8.1",
        "league/route": "^6.2"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/",
            "core\\views\\": "core/views/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2"
    }
}
