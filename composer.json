{
    "version": "11.0.0",
    "name": "felipesantos2/phpmiro",
    "require": {
        "symfony/dotenv": "^8.1",
        "symfony/var-dumper": "*",
        "monolog/monolog": "^3.10",
        "symfony/console": "^8.1",
        "symfony/finder": "^8.1",
        "symfony/http-client": "^8.1",
        "symfony/error-handler": "^8.1",
        "symfony/http-foundation": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/",
            "core\\": "core/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2",
        "squizlabs/php_codesniffer": "3.*",
        "laravel/pint": "^1.29"
    }
}
